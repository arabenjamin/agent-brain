{
  "mcpServers": {
    "api-knowledge-graph": {
      "type": "stdio",
      "command": "/path/to/agent-api/target/release/agent-api",
      "args": [
        "serve"
      ],
      "env": {
        "NEO4J_URI": "bolt://localhost:7688",
        "NEO4J_USER": "neo4j",
        "NEO4J_PASSWORD": "password",
        "OLLAMA_URL": "http://localhost:11434",
        "OLLAMA_MODEL": "llama3"
      }
    }
  }
}

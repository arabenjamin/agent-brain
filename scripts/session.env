# Active self-learning session (2026-02-27)
export BRAIN_SID="7dbaadeb-0e5d-4ce3-bc79-82ce9af123a9"
export BRAIN_TASK_ID="c4c2fa07-4bbd-45d8-951e-7411fda03bd0"
export BRAIN_URL="http://localhost:3001"

# Helper function
brain() {
  local tool="$1"
  local args="$2"
  curl -s -X POST "$BRAIN_URL/mcp" \
    -H "Content-Type: application/json" \
    -H "mcp-session-id: $BRAIN_SID" \
    -d "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"tools/call\",\"params\":{\"name\":\"$tool\",\"arguments\":$args}}" \
    | python3 -c "import sys,json; r=json.load(sys.stdin); print(r['result']['content'][0]['text'])" 2>/dev/null
}

echo "Brain session loaded. Use: brain <tool_name> '<json_args>'"
echo "Example: brain queue_status '{}'"

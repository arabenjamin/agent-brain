# Neo4j Configuration
NEO4J_URI=bolt://localhost:7688
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Ollama Configuration
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=granite4:latest
OLLAMA_EMBED_MODEL=bge-m3:latest

# Logging
LOG_LEVEL=info
LOG_FORMAT=pretty

# MCP Transport Configuration
MCP_TRANSPORT=stdio
# MCP_HTTP_BIND=127.0.0.1:3000
# MCP_API_KEY=your-secret-api-key

# Secret Provider Configuration
# Options: local, vault, aws, none
SECRET_PROVIDER=local

# Local Secret Provider (AES-256-GCM encrypted file)
SECRETS_FILE=.secrets.enc
# IMPORTANT: Set a strong encryption key for production!
# SECRETS_ENCRYPTION_KEY=your-strong-encryption-key-here

# HashiCorp Vault Provider
# VAULT_ADDR=https://vault.example.com:8200
# VAULT_TOKEN=your-vault-token
# VAULT_MOUNT_PATH=secret
# VAULT_NAMESPACE=your-namespace  # Optional, for Vault Enterprise

# AWS Secrets Manager Provider
# AWS_REGION=us-east-1
# AWS_SECRET_PREFIX=/agent-brain/  # Optional prefix for secret names

# LLM Provider Configuration
# Options: ollama (default), anthropic, gemini
LLM_PROVIDER=ollama

# Anthropic Configuration
# ANTHROPIC_API_KEY=your-api-key
# ANTHROPIC_MODEL=claude-3-5-sonnet-20240620

# Gemini Configuration
# GEMINI_API_KEY=your-api-key
# GEMINI_MODEL=gemini-1.5-pro

# vLLM / OpenAI-compatible Configuration (LLM_PROVIDER=vllm)
# Works with: vLLM, LM Studio, Jan.ai, LocalAI, Groq, Together AI, etc.
#
# Recommended models (brain research 2026-03-03):
#   8 GB GPU  (RTX 3060 Ti / 3090):  Qwen/Qwen3-8B-AWQ  (--max-model-len 4096)
#   24 GB GPU (RTX 4090):             Qwen/Qwen3-8B  or  Qwen/Qwen2.5-14B-Instruct-AWQ
#   80 GB GPU (A100 / H100):          Qwen/Qwen3-32B
#
# Serve the primary model (tool-use / reasoning):
#   vllm serve Qwen/Qwen3-8B-AWQ --enable-auto-tool-choice --tool-call-parser hermes \
#              --max-model-len 4096 --gpu-memory-utilization 0.80
#
# VLLM_URL=http://localhost:8000
# VLLM_MODEL=Qwen/Qwen3-8B-AWQ
# VLLM_API_KEY=                        # optional; for secured deployments
#
# Dedicated embedding endpoint (BAAI/bge-m3, 1024-dim, matches Neo4j vector index):
#   vllm serve BAAI/bge-m3 --task embed \
#              --hf-overrides '{"architectures": ["BgeM3EmbeddingModel"]}' \
#              --max-model-len 8192 --device cpu --port 8001
#
# VLLM_EMBED_URL=http://localhost:8001
# VLLM_EMBED_MODEL=BAAI/bge-m3

# Sleep / Training Data Export
# DATASET_DIR=./datasets
# TELEMETRY_DB_PATH=brain_logs.db  # Enable DuckDB interaction logging (required for SleepSkill)

# Web Search (search_web tool) - configure at least one
# SERPAPI_KEY=your-serpapi-key
# BRAVE_API_KEY=your-brave-api-key
# GOOGLE_API_KEY=your-google-api-key
# GOOGLE_CX=your-google-custom-search-engine-id

# Autonomous Scheduler
# SCHEDULER_INTERVAL_SECS=300  # How often the scheduler polls for pending tasks (seconds)
# SCHEDULER_ENABLED=true        # Set to false to start with scheduler disabled

# Knowledge Graph Snapshots
# KNOWLEDGE_SNAPSHOT_DIR=./snapshots              # Directory for .json.gz snapshot files
# AUTO_SNAPSHOT_BEFORE_CONSOLIDATION=true         # Take snapshot before consolidate_memories runs
# AUTO_SNAPSHOT_BEFORE_PRUNE=false                # Take snapshot before prune_old_notes runs

# Context Profiles
# CONTEXTS_DIR=./contexts                         # Directory for YAML context profile files
